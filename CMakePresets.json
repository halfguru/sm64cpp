{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "msys-ninja",
      "displayName": "MSYS2 Clang++ (Ninja)",
      "description": "Configure build for MSYS2 using Clang++ and Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_cmake",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "C:/Program Files/LLVM/bin/clang++.exe",
        "CMAKE_C_COMPILER": "C:/Program Files/LLVM/bin/clang.exe",
        "CMAKE_RC_COMPILER": "C:/msys64/mingw64/bin/windres.exe",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "msvc-ninja",
      "displayName": "MSVC (Ninja)",
      "description": "Configure build for MSVC using Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_msvc_ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "msvc-vs",
      "displayName": "Visual Studio MSVC",
      "description": "Configure build for MSVC using Visual Studio 2022",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build_msvc_vs",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msys-ninja",
      "displayName": "MSYS2 Clang++ Build",
      "configurePreset": "msys-ninja"
    },
    {
      "name": "msvc-ninja",
      "displayName": "MSVC Ninja Build",
      "configurePreset": "msvc-ninja"
    },
    {
      "name": "msvc-vs",
      "displayName": "MSVC Visual Studio Build",
      "configurePreset": "msvc-vs"
    }
  ]
}
